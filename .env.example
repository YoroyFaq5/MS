FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-me-in-production-use-a-long-random-string

# Обязателен — приложение не запустится без него (см. app/config.py).
# База данных должна быть создана с CHARACTER SET utf8mb4 (см. README) —
# приложение русскоязычное и хранит эмодзи в некоторых текстовых полях.
DATABASE_URL=mysql+pymysql://user:password@localhost/mafia_style?charset=utf8mb4

# Migration API (/migration/*) — ТОЛЬКО на время одноразового переноса
# данных из старой версии приложения. По умолчанию выключен (роутов не
# существует вообще, 404). Включить на время миграции, затем убрать обе
# переменные из .env — это и есть выключатель.
# MIGRATION_API_ENABLED=true
# MIGRATION_API_TOKEN=сгенерируй-длинный-случайный-секрет-сюда
